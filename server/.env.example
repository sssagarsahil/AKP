# MongoDB Atlas connection string
# 1. Go to https://www.mongodb.com/cloud/atlas and create a free account
# 2. Create a free M0 cluster (choose a region close to you)
# 3. Under "Database Access", create a database user with a password
# 4. Under "Network Access", add 0.0.0.0/0 to allow all IPs (for dev)
# 5. Click "Connect" on your cluster → "Connect your application"
# 6. Copy the connection string and replace <password> with your DB user password
# 7. Create a file called .env (copy this file) and paste the string below

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/akshaypatra?retryWrites=true&w=majority
JWT_SECRET=akshaypatra-heritage-secret-key-2024
PORT=8082
